# ─────────────────────────────────────────────
# Email notifications — OPTIONAL
# Leave blank to skip email; owner still gets orders via admin dashboard.
# When client is ready: sign up at https://resend.com (free, 3k/month)
# ─────────────────────────────────────────────
RESEND_API_KEY=                                  # re_xxxxxxxxxxxx  (leave blank to disable)
OWNER_EMAIL=                                     # owner@clientdomain.com

# ─────────────────────────────────────────────
# Admin panel credentials (both required)
# ─────────────────────────────────────────────
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-admin-password
