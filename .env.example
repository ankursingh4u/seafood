# ─────────────────────────────────────────────
# Supabase (required)
# Get these from: Supabase Dashboard → Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key       # server-side only, never expose to browser

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key      # safe for browser (admin realtime)

# ─────────────────────────────────────────────
# Email notifications — OPTIONAL
# Leave blank to skip email; owner still gets orders via admin dashboard.
# When client is ready: sign up at https://resend.com (free, 3k/month)
# ─────────────────────────────────────────────
RESEND_API_KEY=                                  # re_xxxxxxxxxxxx  (leave blank to disable)
OWNER_EMAIL=                                     # owner@clientdomain.com

# ─────────────────────────────────────────────
# Admin panel (Dev C)
# ─────────────────────────────────────────────
ADMIN_PASSWORD=your-strong-admin-password
