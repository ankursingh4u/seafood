# ─────────────────────────────────────────────
# Supabase (required)
# Get these from: Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key       # server-side only, never expose to browser

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key      # safe for browser (Dev C admin realtime)

# ─────────────────────────────────────────────
# Email notifications (Nodemailer)
# For Gmail: enable 2FA → generate App Password → use here
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password                      # Gmail App Password (not your real password)
OWNER_EMAIL=owner@example.com                    # Where order emails are sent

# ─────────────────────────────────────────────
# Admin panel (Dev C)
# ─────────────────────────────────────────────
ADMIN_PASSWORD=your-strong-admin-password
